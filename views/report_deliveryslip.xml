<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Main Delivery Slip Document -->
    <template id="report_delivery_document_inherit_prices" inherit_id="stock.report_delivery_document">
        <!-- Hide Ordered Column header in non-done state -->
        <xpath expr="//th[@name='th_sm_ordered']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>

        <!-- Hide Ordered Column cell in non-done state -->
        <xpath expr="//table[@name='stock_move_table']/tbody/tr/td[2]" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>

        <!-- Hide Ordered Column header in done state -->
        <xpath expr="//th[@name='th_sml_qty_ordered']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>

        <!-- Override lot_serial header to not use t-else so it doesn't render when has_serial_number is False -->
        <xpath expr="//th[@name='lot_serial']" position="attributes">
            <attribute name="t-if">has_serial_number</attribute>
        </xpath>

        <!-- 1. Table Non-Done state: add headers -->
        <xpath expr="//table[@name='stock_move_table']/thead/tr" position="inside">
            <t t-if="o.sale_id">
                <th class="text-end"><strong>Prix unitaire</strong></th>
                <th class="text-end"><strong>Rem. %</strong></th>
                <th class="text-end"><strong>Taxes</strong></th>
                <th class="text-end"><strong>Montant</strong></th>
            </t>
        </xpath>

        <!-- 2. Table Non-Done state: add columns -->
        <xpath expr="//table[@name='stock_move_table']/tbody/tr" position="inside">
            <t t-if="o.sale_id">
                <td class="text-end text-nowrap">
                    <span t-field="move.sale_line_id.price_unit" t-options='{"widget": "monetary", "display_currency": o.sale_id.currency_id}'/>
                </td>
                <td class="text-end">
                    <span t-if="move.sale_line_id.discount > 0">
                        <span t-field="move.sale_line_id.discount"/> %
                    </span>
                    <span t-else="">-</span>
                </td>
                <td class="text-end">
                    <span t-esc="', '.join(move.sale_line_id.tax_ids.mapped('name'))"/>
                </td>
                <td class="text-end text-nowrap">
                    <span t-field="move.sale_line_id.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.sale_id.currency_id}'/>
                </td>
            </t>
        </xpath>

        <!-- 3. Table Done state: add headers -->
        <xpath expr="//table[@name='stock_move_line_table']/thead/tr" position="inside">
            <t t-if="o.sale_id">
                <th class="text-end">Prix unitaire</th>
                <th class="text-end">Rem. %</th>
                <th class="text-end">Taxes</th>
                <th class="text-end">Montant</th>
            </t>
        </xpath>

        <!-- 4. Inject Totals block above Signature (narrowed to col-4, mt-2 for clean look) -->
        <xpath expr="//div[@name='signature']" position="before">
            <div t-if="o.sale_id" class="clearfix mb-3" name="so_total_summary" style="page-break-inside: avoid;">
                <div id="total" class="row mt-2">
                    <div class="col-4 ms-auto">
                        <table class="table table-sm table-borderless">
                            <t t-call="sale.document_tax_totals">
                                <t t-set="tax_totals" t-value="o.sale_id.tax_totals"/>
                                <t t-set="currency" t-value="o.sale_id.currency_id"/>
                            </t>
                        </table>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Inherit Serial/Lot Move Line template -->
    <template id="stock_report_delivery_has_serial_move_line_inherit" inherit_id="stock.stock_report_delivery_has_serial_move_line">
        <xpath expr="//td[@name='move_line_lot_quantity']" position="after">
            <t t-if="move_line.picking_id.sale_id">
                <td class="text-end text-nowrap">
                    <span t-field="move_line.move_id.sale_line_id.price_unit" t-options='{"widget": "monetary", "display_currency": move_line.picking_id.sale_id.currency_id}'/>
                </td>
                <td class="text-end">
                    <span t-if="move_line.move_id.sale_line_id.discount > 0">
                        <span t-field="move_line.move_id.sale_line_id.discount"/> %
                    </span>
                    <span t-else="">-</span>
                </td>
                <td class="text-end">
                    <span t-esc="', '.join(move_line.move_id.sale_line_id.tax_ids.mapped('name'))"/>
                </td>
                <td class="text-end text-nowrap">
                    <span t-field="move_line.move_id.sale_line_id.price_subtotal" t-options='{"widget": "monetary", "display_currency": move_line.picking_id.sale_id.currency_id}'/>
                </td>
            </t>
        </xpath>
    </template>

    <!-- Inherit Aggregated Move Line template -->
    <template id="stock_report_delivery_aggregated_move_lines_inherit" inherit_id="stock.stock_report_delivery_aggregated_move_lines">
        <!-- Hide Ordered Column cell -->
        <xpath expr="//td[@name='move_line_aggregated_qty_ordered']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>

        <!-- Inject price, discount, tax, subtotal cells -->
        <xpath expr="//td[@name='move_line_aggregated_quantity']" position="after">
            <t t-set="move" t-value="aggregated_lines[line].get('move')"/>
            <t t-if="move and move.picking_id.sale_id">
                <td class="text-end text-nowrap">
                    <span t-field="move.sale_line_id.price_unit" t-options='{"widget": "monetary", "display_currency": move.picking_id.sale_id.currency_id}'/>
                </td>
                <td class="text-end">
                    <span t-if="move.sale_line_id.discount > 0">
                        <span t-field="move.sale_line_id.discount"/> %
                    </span>
                    <span t-else="">-</span>
                </td>
                <td class="text-end">
                    <span t-esc="', '.join(move.sale_line_id.tax_ids.mapped('name'))"/>
                </td>
                <td class="text-end text-nowrap">
                    <span t-field="move.sale_line_id.price_subtotal" t-options='{"widget": "monetary", "display_currency": move.picking_id.sale_id.currency_id}'/>
                </td>
            </t>
        </xpath>
    </template>
</odoo>
